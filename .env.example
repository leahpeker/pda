# Database
DATABASE_URL=postgresql://pda:pda@localhost:5432/pda

# Django
DEBUG=True
SECRET_KEY=

# Vetting
VETTING_EMAIL=

# Email (optional — leave empty for console backend in dev)
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# GitHub App feedback (optional — leave empty to disable feedback button)
# Credentials are in 1Password: "PDAFeedbackForm" (Shared vault)
#
# Populate with 1Password CLI:
#   GITHUB_APP_ID=$(op item get PDAFeedbackForm --fields "App ID")
#   GITHUB_APP_INSTALLATION_ID=$(op item get PDAFeedbackForm --fields "PDA Installation ID")
#   GITHUB_APP_PRIVATE_KEY=$(op read "op://Shared/PDAFeedbackForm/add more/pdafeedbackform.2026-03-31.private-key.pem" | base64 | tr -d '\n')
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_REPO=ProteinDeficientsAnonymous/pda

# WhatsApp bot (optional — leave empty to disable notifications)
WHATSAPP_BOT_URL=http://localhost:3001
WHATSAPP_BOT_SECRET=
WHATSAPP_GROUP_ID=

# Backblaze B2 media storage (optional — leave empty for local filesystem in dev)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT_URL=
B2_REGION=
